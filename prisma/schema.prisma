// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model songs {
  song_id       Int             @id @default(autoincrement())
  users         users           @relation(fields: [user_id], references: [user_id])
  user_id       Int
  title         String
  artists       String
  name          String
  addition_date DateTime?
  release_date  DateTime
  file          String?
  mood          mood            @relation(fields: [mood_id], references: [mood_id])
  mood_id       Int
  rank          String?
  bpm           Float?
  bitrate_audio BigInt?
  track_gain    Float?
  description   String?
  image         String?
  songsAlbums   songs_albums[]
  songsGroupes  songs_groupes[]
  songsGenres   songs_genres[]
  songsPeople   songs_people[]
  songsLyrics   songs_lyrics[]
}

model mood {
  mood_id Int     @id @default(autoincrement())
  mood    String
  songs   songs[]
}

model albums {
  id           Int            @id @default(autoincrement())
  name         String
  author       String?
  release_date DateTime?
  album_types  album_types?   @relation(fields: [album_type], references: [album_type_id], onDelete: Cascade)
  album_type   Int?
  description  String?
  image        String?
  songsAlbums  songs_albums[]
}

model album_types {
  album_type_id Int      @id @default(autoincrement())
  album_type    String
  albums        albums[]
}

model songs_albums {
  songs   songs  @relation(fields: [song_id], references: [song_id], onDelete: Cascade)
  albums  albums @relation(fields: [id], references: [id])
  song_id Int
  id      Int
  track   Int?
  disk    Int?

  @@id([song_id, id])
}

model countries {
  country_id Int       @id @default(autoincrement())
  country    String
  groupes    groupes[]
  people     people[]
}

model groupes {
  id                 Int             @id @default(autoincrement())
  name               String
  year_of_foundation Int?
  countries          countries?      @relation(fields: [country_id], references: [country_id])
  country_id         Int?
  description        String?
  image              String?
  songsGroupes       songs_groupes[]
}

model songs_groupes {
  songs   songs   @relation(fields: [song_id], references: [song_id], onDelete: Cascade)
  groupes groupes @relation(fields: [id], references: [id])
  song_id Int
  id      Int

  @@id([song_id, id])
}

model people {
  id          Int            @id @default(autoincrement())
  name        String
  firstname   String?
  surname     String?
  nickname    String?
  description String?
  image       String?
  countries   countries?     @relation(fields: [country_id], references: [country_id])
  country_id  Int?
  songsPeople songs_people[]
  peopleType  people_type[]
}

model type {
  type_id    Int           @id @default(autoincrement())
  name       String
  peopleType people_type[]
}

model songs_people {
  songs   songs  @relation(fields: [song_id], references: [song_id], onDelete: Cascade)
  people  people @relation(fields: [id], references: [id])
  song_id Int
  id      Int

  @@id([song_id, id])
}

model people_type {
  type    type   @relation(fields: [type_id], references: [type_id], onDelete: Cascade)
  people  people @relation(fields: [id], references: [id])
  type_id Int
  id      Int

  @@id([type_id, id])
}

model genres {
  id          Int            @id @default(autoincrement())
  name        String
  songsGenres songs_genres[]
}

model songs_genres {
  songs   songs  @relation(fields: [song_id], references: [song_id], onDelete: Cascade)
  genres  genres @relation(fields: [id], references: [id])
  song_id Int
  id      Int

  @@id([song_id, id])
}

model languages {
  language_id Int            @id @default(autoincrement())
  lang        String
  songsLyrics songs_lyrics[]
}

model songs_lyrics {
  songs       songs     @relation(fields: [song_id], references: [song_id], onDelete: Cascade)
  languages   languages @relation(fields: [language_id], references: [language_id], onDelete: Cascade)
  song_id     Int
  language_id Int
  lyrics_text String

  @@id([song_id, language_id])
}

model users {
  user_id      Int     @id @default(autoincrement())
  email        String  @unique
  passwordHash String
  name         String
  contactPhone String?
  role         String  @default("client")
  songs        songs[]
}
